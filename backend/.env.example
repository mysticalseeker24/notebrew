# ═══════════════════════════════════════════════════
# NoteBrew — Environment Variables
# ═══════════════════════════════════════════════════

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Selection
PRIMARY_MODEL=gemini-3-flash-preview
FALLBACK_MODEL=minimax-m2.5
ORCHESTRATION_MODEL=minimax-m2.5
PLANNING_MODEL=minimax-m2.5
CODEGEN_MODEL=minimax-m2.5

# Server Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=False

# File Upload Configuration
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Agent Configuration
AGENT_MAX_ITERATIONS=15
AGENT_MAX_RETRIES=3
AGENT_TOOL_TIMEOUT=120
MAX_LLM_CALLS_PER_TASK=20
MAX_GENERATE_CODE_CALLS=8
MAX_RUNTIME_SECONDS=120
MAX_RETRY_PER_TOOL=2
CODE_CELL_REGEN_RETRIES=1
MAX_NOTEBOOK_CELLS=8
MAX_NOTEBOOK_CODE_CELLS=3
PDF_CHUNK_ENABLED=True
PDF_CHUNK_PAGE_SIZE=5
PDF_CHUNK_MIN_PAGES=10
PDF_CHUNK_MAX_CONCURRENCY=3

# Notebook Hosting / Launch Links
# Set this to a public base URL where generated .ipynb files are served.
# Example: https://your-domain.com/notebooks
PUBLIC_NOTEBOOK_BASE_URL=

# Templates support {notebook_url} and {notebook_url_encoded}
COLAB_URL_TEMPLATE=https://colab.research.google.com/#fileId={notebook_url_encoded}
KAGGLE_URL_TEMPLATE=https://www.kaggle.com/code?url={notebook_url_encoded}

# Docling Configuration
DOCLING_OCR_ENABLED=True
DOCLING_EXTRACT_FIGURES=True
DOCLING_EXTRACT_TABLES=True
